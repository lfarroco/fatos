{
	"name": "@fatos/schema-designer",
	"version": "0.0.1",
	"description": "Schema designer models, validation, and adapters for Fatos",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./react": {
			"types": "./dist/react.d.ts",
			"import": "./dist/react.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup src/index.ts src/react.ts --format esm --dts --sourcemap",
		"dev": "tsup src/index.ts src/react.ts --format esm --dts --sourcemap --watch",
		"preview": "esbuild src/preview.tsx --bundle --format=esm --sourcemap --outfile=preview/app.js --servedir=preview --serve=4173",
		"test": "vitest",
		"lint": "eslint src",
		"types": "tsc --noEmit"
	},
	"keywords": [
		"schema",
		"designer",
		"er",
		"json",
		"fatos"
	],
	"author": "",
	"license": "MIT",
	"dependencies": {},
	"peerDependencies": {
		"react": ">=18.0.0"
	},
	"devDependencies": {
		"@types/node": "^20.10.0",
		"@types/react": "^18.2.0",
		"@types/react-dom": "^18.2.0",
		"esbuild": "^0.25.0",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"typescript": "^5.3.3",
		"tsup": "^8.0.0",
		"vitest": "^1.0.0"
	}
}