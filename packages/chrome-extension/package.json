{
	"name": "@fatos/chrome-extension",
	"version": "0.0.1",
	"description": "Chrome DevTools extension for Fatos",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "tsup src/background.ts src/panel.ts src/content.ts --format iife --dts --sourcemap --splitting=false",
		"dev": "tsup src/background.ts src/panel.ts src/content.ts --format iife --dts --sourcemap --splitting=false --watch",
		"test": "vitest",
		"lint": "eslint src"
	},
	"keywords": [
		"chrome-extension",
		"devtools",
		"inspector"
	],
	"author": "",
	"license": "MIT",
	"dependencies": {
		"@fatos/devtools": "file:../devtools"
	},
	"devDependencies": {
		"@types/node": "^20.10.0",
		"typescript": "^5.3.3",
		"tsup": "^8.0.0",
		"vitest": "^1.0.0"
	}
}